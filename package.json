{
    "name": "@boon4681/giri",
    "version": "0.0.2-alpha-3",
    "license": "MIT",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
        "giri": "./dist/cli.js"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./hono": {
            "types": "./dist/adapters/hono.d.ts",
            "default": "./dist/adapters/hono.js"
        },
        "./adapters/hono": {
            "types": "./dist/adapters/hono.d.ts",
            "default": "./dist/adapters/hono.js"
        },
        "./validators/zod": {
            "types": "./dist/validators/zod.d.ts",
            "default": "./dist/validators/zod.js"
        },
        "./validators/valibot": {
            "types": "./dist/validators/valibot.d.ts",
            "default": "./dist/validators/valibot.js"
        },
        "./tsc": {
            "types": "./dist/typescript-plugin.d.ts",
            "require": "./dist/typescript-plugin.js",
            "default": "./dist/typescript-plugin.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsx ./build.ts",
        "test": "vitest --run",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@clack/prompts": "^1.5.1",
        "@hono/standard-validator": "^0.2.1",
        "@sinclair/typebox": "^0.34.49",
        "esbuild": "^0.27.7",
        "esbuild-register": "^3.6.0",
        "openapi-types": "^12.1.3",
        "tinyglobby": "^0.2.16"
    },
    "devDependencies": {
        "@hono/node-server": "^2.0.3",
        "@types/node": "^25.9.1",
        "@valibot/to-json-schema": "^1.7.0",
        "hono": "^4.12.18",
        "tsup": "^8.4.0",
        "tsx": "^4.22.4",
        "typescript": "^5.8.3",
        "valibot": "^1.4.1",
        "vite-node": "^3.2.4",
        "vitest": "^3.2.0",
        "zod": "^4.4.3"
    },
    "peerDependencies": {
        "@hono/node-server": "^2.0.0",
        "@valibot/to-json-schema": "^1.0.0",
        "hono": "^4.12.0",
        "typescript": ">=5.4",
        "valibot": "^1.0.0",
        "zod": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "@hono/node-server": {
            "optional": true
        },
        "@valibot/to-json-schema": {
            "optional": true
        },
        "hono": {
            "optional": true
        },
        "valibot": {
            "optional": true
        },
        "zod": {
            "optional": true
        }
    },
    "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
